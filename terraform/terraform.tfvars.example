aws_region    = "eu-north-1"
ami_id        = "ami-001413555755c0cf7"
instance_type = "t3.micro"
key_name      = "hospital-key"
instance_name = "control-node"
security_group_name = "control-node-sg"
security_group_description = "control security group"
security_group_tags = {}
vpc_id        = "vpc-xxxxxxxx"

ingress_rules = [
  {
    description = "SSH from trusted office IP"
    from_port   = 22
    to_port     = 22
    protocol    = "tcp"
    cidr_ipv4   = "203.0.113.10/32"
  }
]

egress_rules = [
  {
    protocol    = "-1"
    cidr_ipv4   = "0.0.0.0/0"
  }
]

worker_ami_id        = "ami-001413555755c0cf7"
worker_instance_type = "t3.micro"
worker_key_name      = "hospital-key"
worker_instance_name = "worker-node"
worker_security_group_name = "worker-node-sg"
worker_security_group_description = "worker security group"
worker_security_group_tags = {}

worker_ingress_rules = [
  {
    from_port = 22
    to_port   = 22
    protocol  = "tcp"
    cidr_ipv4 = "203.0.113.10/32"
  }
]

worker_egress_rules = [
  {
    protocol  = "-1"
    cidr_ipv4 = "0.0.0.0/0"
  }
]
